# Storage backend: json | sqlite | postgres
STORAGE_BACKEND=json
STORAGE_PATH=./data

# X (Twitter) session cookies - required for crawling (export from your browser)
X_AUTH_TOKEN=your_auth_token_here
X_CT0=your_ct0_token_here

# Twitter/X
TWITTER_BEARER_TOKEN=

# YouTube
YOUTUBE_API_KEY=

# Generic cookie-based auth (Facebook, Instagram, TikTok, LinkedIn)
FACEBOOK_COOKIES=
INSTAGRAM_COOKIES=
TIKTOK_COOKIES=
LINKEDIN_COOKIES=
